{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "label": "npm: build",
      "problemMatcher": ["$tsc"],
      "presentation": { "reveal": "silent" },
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "type": "npm",
      "script": "watch",
      "label": "npm: watch",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^(.*)$", "file": 1, "location": 1, "message": 1 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^watching for changes",
          "endsPattern": "^watching for changes"
        }
      },
      "presentation": { "reveal": "never" }
    }
  ]
}
